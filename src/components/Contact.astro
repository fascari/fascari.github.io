---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['contact'];
}

const { t } = Astro.props;
---

<section id="contact">
  <div class="contact-wrapper">

    <div class="contact-glow" aria-hidden="true"></div>

    <div class="contact-content">
      <span class="section-label">{t.label}</span>
      <h2 class="contact-heading">{t.title}</h2>
      <p class="contact-subtitle">{t.subtitle}</p>

      <a href="mailto:felipeascari@gmail.com" class="email-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        <span class="email-text"></span>
      </a>

      <div class="social-row">

        <a href="https://www.linkedin.com/in/felipeascari" class="social-chip linkedin" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          LinkedIn
        </a>

        <a href="https://github.com/fascari" class="social-chip github" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.745 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>

        <a href="https://medium.com/@felipe.ascari_49171" class="social-chip medium" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/>
          </svg>
          Medium
        </a>

        <a href="https://dev.to/felipe_ascari" class="social-chip devto" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6l.02 2.44.04 2.45.56-.02c.41 0 .63-.07.83-.26.24-.24.26-.36.26-2.2 0-1.91-.02-1.96-.29-2.18zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.32 2.57.05 2.23-.02 2.73-.47 3.3zm5.09-5.47h-2.47v1.77h1.52v1.28l-.72.04-.75.03v1.77l1.22.03 1.2.04v1.28h-1.6c-1.53 0-1.6-.01-1.87-.3l-.3-.28v-3.16c0-3.02.01-3.18.25-3.48.23-.31.25-.31 1.88-.31h1.64v1.29zm4.68 5.45c-.17.43-.64.79-1 .79-.18 0-.45-.15-.67-.39-.32-.32-.45-.63-.82-2.08l-.9-3.39-.45-1.67h.76c.4 0 .75.02.75.05 0 .06 1.16 4.54 1.26 4.83.04.15.32-.7.73-2.3l.66-2.52.74-.04c.4-.02.73 0 .73.04 0 .14-1.67 6.38-1.8 6.68z"/>
          </svg>
          DEV.to
        </a>

      </div>
    </div>

  </div>
</section>

<script>
  const u = 'felipeascari';
  const d = 'gmail.com';
  const addr = u + '@' + d;
  const link = document.querySelector('a.email-link') as HTMLAnchorElement | null;
  if (link) {
    link.href = 'mailto:' + addr;
    const span = link.querySelector('.email-text');
    if (span) span.textContent = addr;
  }
</script>

<style>
  section {
    padding-top: 100px;
  }

  .contact-wrapper {
    position: relative;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 32px;
  }

  .contact-glow {
    position: absolute;
    bottom: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 300px;
    background: radial-gradient(ellipse, rgba(56, 189, 248, 0.09) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .contact-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 72px 32px 80px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: linear-gradient(160deg, rgba(56, 189, 248, 0.04) 0%, transparent 50%);
  }

  .contact-heading {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--text);
    margin-top: 16px;
    margin-bottom: 16px;
  }

  .contact-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 440px;
    margin-bottom: 40px;
  }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 0.88rem;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
    margin-bottom: 36px;
    transition: color 0.2s, border-color 0.2s;
  }

  .email-link:hover {
    color: var(--text);
    border-color: var(--text-subtle);
  }

  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .social-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border-radius: 99px;
    font-size: 0.83rem;
    font-weight: 500;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-muted);
    transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s;
  }

  .social-chip:hover {
    transform: translateY(-2px);
  }

  .social-chip.linkedin:hover {
    color: #5ba3f5;
    border-color: rgba(91, 163, 245, 0.4);
    background: rgba(91, 163, 245, 0.08);
  }

  .social-chip.github:hover {
    color: #e8e8e8;
    border-color: rgba(232, 230, 240, 0.3);
    background: rgba(232, 230, 240, 0.06);
  }

  .social-chip.medium:hover {
    color: #7da8c9;
    border-color: rgba(125, 168, 201, 0.35);
    background: rgba(125, 168, 201, 0.08);
  }

  .social-chip.devto:hover {
    color: #38bdf8;
    border-color: rgba(56, 189, 248, 0.35);
    background: rgba(56, 189, 248, 0.08);
  }

  @media (max-width: 640px) {
    .contact-wrapper { padding: 0 20px; }
    .contact-content { padding: 48px 24px 56px; }
  }
</style>
