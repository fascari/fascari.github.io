---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['articles'];
}

const { t } = Astro.props;
---

<section id="articles">
  <div class="section-wrapper">
    <div class="section-header">
      <span class="section-label">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <div class="section-line"></div>
    </div>
    <div
      id="articles-grid"
      class="articles-grid"
      data-min-read={t.minRead}
      data-error={t.error}
      data-locale={t.locale}
    ></div>
  </div>
</section>

<style>
  section {
    padding-top: 80px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  @media (max-width: 640px) {
    .articles-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  function extractThumb(item: { cover_image?: string; content?: string }): string | null {
    if (item.cover_image) return item.cover_image;
    if (item.content) {
      const m = item.content.match(/<img[^>]+src="([^"]+)"/);
      if (m) return m[1];
    }
    return null;
  }

  function stripHtml(html: string): string {
    return html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
  }

  function estimateReadTime(text: string, label: string): string {
    const words = stripHtml(text || '').split(/\s+/).filter(Boolean).length;
    const mins = Math.max(1, Math.round(words / 200));
    return `${mins} ${label}`;
  }

  function formatDate(dateStr: string, locale: string): string {
    try {
      return new Date(dateStr).toLocaleDateString(locale, {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
    } catch {
      return '';
    }
  }

  function sourceLabel(source: string): string {
    if (source === 'devto') return 'DEV.to';
    if (source === 'linkedin') return 'LinkedIn';
    if (source === 'medium') return 'Medium';
    return source.charAt(0).toUpperCase() + source.slice(1);
  }

  function formatTag(tag: string): string {
    return tag.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  }

  const grid = document.getElementById('articles-grid')!;
  const minRead = grid.dataset.minRead || 'min read';
  const locale = grid.dataset.locale || 'en-US';
  const errorMsg = grid.dataset.error || 'Could not load articles.';

  grid.innerHTML = Array.from({ length: 6 }, () => `
    <div class="skeleton">
      <div class="skeleton-thumb"></div>
      <div class="skeleton-body">
        <div class="skeleton-line" style="width:40%"></div>
        <div class="skeleton-line" style="width:85%"></div>
        <div class="skeleton-line" style="width:65%"></div>
      </div>
    </div>
  `).join('');

  fetch('/articles.json')
    .then((r) => r.json())
    .then((all: Array<{
      title: string;
      link: string;
      pubDate: string;
      description: string;
      content: string;
      cover_image?: string;
      source?: string;
      tags?: string[];
    }>) => {
      const articles = all.slice(0, 6);
      grid.innerHTML = articles.map((item) => {
        const thumb = extractThumb(item);
        const source = item.source || 'medium';
        const tags = (item.tags ?? []).slice(0, 3);

        // prefer description (plain); fall back to content (HTML) for Medium
        const richText = item.description && item.description.trim()
          ? item.description
          : stripHtml(item.content || '');
        const plain = stripHtml(richText);

        // truncate at last sentence boundary within 280 chars, no ellipsis
        function toSentence(text: string, max: number): string {
          if (text.length <= max) return text;
          const chunk = text.slice(0, max);
          const end = Math.max(chunk.lastIndexOf('.'), chunk.lastIndexOf('!'), chunk.lastIndexOf('?'));
          return end > 60 ? text.slice(0, end + 1) : chunk.trimEnd();
        }
        const excerpt = toSentence(plain, 280);

        return `
          <a class="article" href="${item.link}" target="_blank" rel="noopener noreferrer">
            ${thumb
              ? `<img class="article-thumb" src="${thumb}" alt="${item.title}" loading="lazy" />`
              : `<div class="article-thumb-placeholder">${item.title.slice(0, 2).toUpperCase()}</div>`
            }
            <div class="article-body">
              <div class="article-tags">
                <span class="platform-badge" data-source="${source}">${sourceLabel(source)}</span>
                ${tags.map(tag => `<span class="article-tag">${formatTag(tag)}</span>`).join('')}
              </div>
              <div class="article-title">${item.title}</div>
              <div class="article-excerpt">${excerpt}</div>
              <div class="article-footer">
                <span class="article-date">${formatDate(item.pubDate, locale)}</span>
                <span class="article-readtime">${estimateReadTime(plain, minRead)}</span>
              </div>
            </div>
          </a>
        `;
      }).join('');
    })
    .catch(() => {
      grid.innerHTML = `<p style="color:var(--text-muted);grid-column:1/-1">${errorMsg}</p>`;
    });
</script>
