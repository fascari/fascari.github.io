---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['about'];
}

const { t } = Astro.props;
---

<section id="about">
  <div class="section-wrapper">
    <div class="section-header">
      <span class="section-label">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <div class="section-line"></div>
    </div>
    <p class="about-bio">{t.bio}</p>
  </div>
</section>

<style>
  section {
    padding-top: 80px;
  }

  .about-bio {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.85;
    max-width: 740px;
    text-align: justify;
  }
</style>
