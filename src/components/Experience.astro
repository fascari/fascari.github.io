---
import { experience } from '../data/experience';
import type { Translations, Lang } from '../i18n/translations';

interface Props {
  t: Translations['experience'];
  lang: Lang;
}

const { t, lang } = Astro.props;
---

<section id="experience">
  <div class="section-wrapper">
    <div class="section-header">
      <span class="section-label">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <div class="section-line"></div>
    </div>

    <div class="exp-tabs">
      <!-- Tab buttons -->
      <div class="tab-list" role="tablist">
        {experience.map((entry, i) => (
          <button
            class={`tab-btn${i === 0 ? ' active' : ''}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-index={i}
          >
            {entry.company}
          </button>
        ))}
        <div class="tab-indicator" aria-hidden="true"></div>
      </div>

      <!-- Tab panels -->
      <div class="tab-panels">
        {experience.map((entry, i) => (
          <div
            class={`tab-panel${i === 0 ? ' active' : ''}`}
            role="tabpanel"
            data-index={i}
          >
            <div class="panel-header">
              <h3 class="panel-role">
                {lang === 'pt' ? entry.rolePt : entry.role}
                <span class="panel-company"> @ {entry.company}</span>
              </h3>
              <div class="panel-meta">
                <span class="panel-period">{entry.period}</span>
                {entry.current && <span class="current-badge">{t.current}</span>}
              </div>
            </div>
            <p class="panel-desc">{lang === 'pt' ? entry.descriptionPt : entry.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding-top: 80px;
  }

  .exp-tabs {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 0 40px;
    min-height: 280px;
  }

  /* ── Tab list ── */
  .tab-list {
    position: relative;
    display: flex;
    flex-direction: column;
    border-left: 2px solid var(--border);
  }

  .tab-btn {
    all: unset;
    cursor: pointer;
    padding: 12px 20px;
    font-size: 0.83rem;
    color: var(--text-subtle);
    text-align: left;
    transition: color 0.2s, background 0.2s;
    border-radius: 0 4px 4px 0;
    position: relative;
    z-index: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tab-btn:hover {
    color: var(--accent);
    background: var(--accent-glow);
  }

  .tab-btn.active {
    color: var(--accent);
  }

  /* sliding accent bar */
  .tab-indicator {
    position: absolute;
    left: -2px;
    width: 2px;
    background: var(--accent);
    border-radius: 2px;
    transition: top 0.25s cubic-bezier(0.4, 0, 0.2, 1), height 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  /* ── Tab panels ── */
  .tab-panels {
    position: relative;
  }

  .tab-panel {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding-top: 4px;
    animation: fadeIn 0.2s ease;
  }

  .tab-panel.active {
    display: flex;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .panel-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .panel-role {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .panel-company {
    color: var(--accent);
    font-weight: 500;
  }

  .panel-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .panel-period {
    font-size: 0.78rem;
    color: var(--text-subtle);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  .current-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--accent-border);
    border-radius: 99px;
    padding: 2px 8px;
  }

  .panel-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 560px;
  }

  /* ── Mobile: stack vertically ── */
  @media (max-width: 640px) {
    .exp-tabs {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .tab-list {
      flex-direction: row;
      overflow-x: auto;
      border-left: none;
      border-bottom: 2px solid var(--border);
      scrollbar-width: none;
    }

    .tab-list::-webkit-scrollbar { display: none; }

    .tab-btn {
      padding: 10px 16px;
      white-space: nowrap;
      border-radius: 4px 4px 0 0;
    }

    .tab-indicator {
      left: 0;
      bottom: -2px;
      top: auto !important;
      width: var(--indicator-width, 80px) !important;
      height: 2px !important;
      transition: left 0.25s cubic-bezier(0.4, 0, 0.2, 1), width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .tab-panels {
      padding-top: 24px;
    }
  }
</style>

<script>
  function initTabs() {
    const list = document.querySelector('.tab-list');
    const buttons = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');
    const indicator = document.querySelector<HTMLElement>('.tab-indicator');

    if (!list || !indicator) return;

    const isMobile = () => window.innerWidth <= 640;

    function moveIndicator(btn: HTMLButtonElement) {
      if (isMobile()) {
        indicator.style.left = btn.offsetLeft + 'px';
        indicator.style.width = btn.offsetWidth + 'px';
        indicator.style.height = '2px';
        indicator.style.top = 'auto';
      } else {
        indicator.style.top = btn.offsetTop + 'px';
        indicator.style.height = btn.offsetHeight + 'px';
        indicator.style.width = '2px';
      }
    }

    function activate(index: number) {
      buttons.forEach((b, i) => {
        b.classList.toggle('active', i === index);
        b.setAttribute('aria-selected', i === index ? 'true' : 'false');
      });
      panels.forEach((p, i) => p.classList.toggle('active', i === index));
      moveIndicator(buttons[index]);
    }

    buttons.forEach((btn, i) => {
      btn.addEventListener('click', () => activate(i));
    });

    // Initial position
    activate(0);

    // Recalculate on resize
    window.addEventListener('resize', () => {
      const active = [...buttons].findIndex(b => b.classList.contains('active'));
      if (active >= 0) moveIndicator(buttons[active]);
    });
  }

  document.addEventListener('DOMContentLoaded', initTabs);
</script>
