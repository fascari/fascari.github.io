---
import { experience } from '../data/experience';
---

<section id="experience">
  <div class="section-wrapper">
    <div class="section-header">
      <span class="section-label">Career</span>
      <h2 class="section-title">Work experience</h2>
      <div class="section-line"></div>
    </div>
    <div class="exp-list">
      {experience.map((entry) => (
        <div class="exp-card">
          <div class="exp-left">
            <span class="exp-period">{entry.period}</span>
            {entry.current && <span class="current-badge">Current</span>}
          </div>
          <div class="exp-right">
            <div class="exp-header">
              <span class="exp-company">{entry.company}</span>
              <span class="exp-role">{entry.role}</span>
            </div>
            <p class="exp-desc">{entry.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding-top: 80px;
  }

  .exp-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .exp-card {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 32px;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
  }

  .exp-card:last-child {
    border-bottom: none;
  }

  .exp-left {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 2px;
  }

  .exp-period {
    font-size: 0.78rem;
    color: var(--text-subtle);
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }

  .current-badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--accent-border);
    border-radius: 99px;
    padding: 2px 8px;
    width: fit-content;
  }

  .exp-right {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .exp-header {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .exp-company {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .exp-role {
    font-size: 0.83rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .exp-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  @media (max-width: 640px) {
    .exp-card {
      grid-template-columns: 1fr;
      gap: 10px;
      padding: 20px 0;
    }
  }
</style>
