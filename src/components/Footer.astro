---
---

<footer>
  <div class="footer-inner">
    <span>© <span id="year"></span> Felipe Ascari</span>
    <div class="footer-links">
      <a href="https://github.com/fascari" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.linkedin.com/in/felipe-ascari/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://medium.com/@felipe.ascari_49171" target="_blank" rel="noopener noreferrer">Medium</a>
    </div>
  </div>
</footer>

<script>
  const el = document.getElementById('year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 100px;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 28px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 0.78rem;
    color: var(--text-subtle);
    flex-wrap: wrap;
  }

  .footer-links {
    display: flex;
    gap: 20px;
  }

  .footer-links a {
    color: var(--text-subtle);
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .footer-inner { padding: 24px 20px; }
  }
</style>
