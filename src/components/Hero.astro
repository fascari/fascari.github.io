<style>
  .hero {
    position: relative;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 96px 32px 88px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 64px;
  }

  .hero-glow {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.05) 0%, transparent 55%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    flex: 1;
    min-width: 0;
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 24px;
    color: var(--text);
  }

  .hero-content p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 600px;
    text-align: justify;
  }

  .links {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .links a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-muted);
    padding: 7px 16px;
    border: 1px solid var(--border);
    border-radius: 99px;
    background: var(--bg-surface);
    transition: color 0.15s, border-color 0.15s, background 0.15s, transform 0.15s;
  }

  .links a:hover {
    color: var(--text);
    border-color: var(--accent-border);
    background: var(--accent-glow);
    transform: translateY(-1px);
  }

  /* Avatar */
  .avatar-wrap {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 270px;
    height: 270px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--accent-border), var(--border) 60%);
  }

  .avatar-wrap img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--bg);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 60px 20px 64px;
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 28px;
    }

    .avatar-wrap {
      width: 100px;
      height: 100px;
    }
  }
</style>
