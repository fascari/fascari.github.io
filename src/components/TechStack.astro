---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations['techStack'];
}

const { t } = Astro.props;

const techs = [
  { name: 'Go',             logo: 'go',                  color: '00ADD8' },
  { name: 'Java',           logo: 'openjdk',             color: 'ED8B00' },
  { name: 'Spring+Boot',    logo: 'springboot',          color: '6DB33F' },
  { name: 'PostgreSQL',     logo: 'postgresql',          color: '4169E1' },
  { name: 'Redis',          logo: 'redis',               color: 'DC382D' },
  { name: 'NATS',           logo: 'natsdotio',           color: '27AAE1' },
  { name: 'gRPC',           logo: 'grpc',                color: '244c5a' },
  { name: 'Ethereum',       logo: 'ethereum',            color: '3C3C3D' },
  { name: 'Docker',         logo: 'docker',              color: '2496ED' },
  { name: 'Kubernetes',     logo: 'kubernetes',          color: '326CE5' },
  { name: 'GitHub+Actions', logo: 'githubactions',       color: '2088FF' },
  { name: 'AWS',            logo: 'amazonwebservices',   color: '232F3E' },
];
---

<section id="stack">
  <div class="section-wrapper">
    <div class="section-header">
      <span class="section-label">{t.label}</span>
      <h2 class="section-title">{t.title}</h2>
      <div class="section-line"></div>
    </div>
    <div class="stack-grid">
      {techs.map((tech) => (
        <img
          class="tech-badge"
          src={`https://img.shields.io/badge/${tech.name}-${tech.color}?style=for-the-badge&logo=${tech.logo}&logoColor=white`}
          alt={tech.name.replace('+', ' ')}
          loading="lazy"
          height="28"
        />
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding-top: 80px;
  }

  .stack-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .tech-badge {
    height: 28px;
    border-radius: 4px;
    display: block;
    opacity: 0.9;
    transition: opacity 0.15s, transform 0.15s;
  }

  .tech-badge:hover {
    opacity: 1;
    transform: translateY(-1px);
  }
</style>
