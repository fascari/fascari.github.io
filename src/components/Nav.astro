---
import type { Translations, Lang } from '../i18n/translations';

interface Props {
  t: Translations['nav'];
  lang: Lang;
}

const { t, lang } = Astro.props;
const homeHref = lang === 'pt' ? '/pt/' : '/';
---

<nav>
  <div class="nav-inner">
    <a href={homeHref} class="nav-logo">fascari<span>.</span></a>
    <div class="nav-links">
      <a href="#about">{t.about}</a>
      <a href="#stack">{t.stack}</a>
      <a href="#experience">{t.work}</a>
      <a href="#projects">{t.projects}</a>
      <a href="#articles">{t.articles}</a>
      <a href="#contact">{t.contact}</a>
    </div>
    <div class="lang-switcher">
      <a href="/" class:list={['lang-btn', { active: lang === 'en' }]}>EN</a>
      <span class="lang-sep">|</span>
      <a href="/pt/" class:list={['lang-btn', { active: lang === 'pt' }]}>PT</a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    background: rgba(12, 12, 12, 0.88);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 32px;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-logo {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-right: auto;
  }

  .nav-logo span {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 4px;
  }

  .nav-links a {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-muted);
    padding: 5px 12px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .nav-links a:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.05);
  }

  /* Language switcher */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--border);
    border-radius: 99px;
    padding: 3px 10px;
    margin-left: 8px;
  }

  .lang-sep {
    font-size: 0.72rem;
    color: var(--border);
  }

  .lang-btn {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-subtle);
    padding: 2px 4px;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .lang-btn:hover {
    color: var(--text-muted);
  }

  .lang-btn.active {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .nav-inner { padding: 0 20px; }
    .nav-links { display: none; }
  }
</style>
